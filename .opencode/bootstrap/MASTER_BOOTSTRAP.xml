  <!-- ===== SESSION PERSISTENCE PROTOCOL ===== -->
  <session-persistence>
    <problem>Every session disconnection causes model to lose context. Model must re-learn project state.</problem>
    <solution>Checkpoint-based recovery: before closing or on context pressure, save state to memory files.</solution>
    <checkpoint-files>
      <file key="notepad">C:\Users\Administrator\.opencode\notepad.md</file>
      <file key="memory">C:\Users\Administrator\.opencode\project-memory.json</file>
      <file key="session-log">C:\Users\Administrator\.opencode\memory\session.log</file>
      <file key="omc-sessions">C:\Users\Administrator\.omc\state\sessions\</file>
    </checkpoint-files>
    <commands>
      <cmd desc="Save current state">/memory save "Done: [task] | Next: [task]"</cmd>
      <cmd desc="List past states">/memory list</cmd>
      <cmd desc="Save checkpoint">cp notepad.md notepad-checkpoint-$(date).md</cmd>
      <cmd desc="Restore last">/memory recall 0</cmd>
    </commands>
    <auto-save>On every task completion, update notepad.md last-action line</auto-save>
  </session-persistence>

