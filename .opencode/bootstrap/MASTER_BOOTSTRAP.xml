      <decision factor="Multi-Model Ingestion" rationale="Gemini exports (MD) + ChatGPT exports (MD) + Claude exports (MD) all funneled into a single Personal Knowledge System." source="Gemini Knowledge System" />
      <decision factor="Claude as Lead Brain" rationale="Claude Desktop as the central synthesizer and thesis assistant, with Gemini/GPT as secondary sources." source="Gemini Knowledge System" />
    </phase>
    <phase name="ABC-Wilson Dynamic Integration" desc="Real-time feedback loop between classification and EOQ">
